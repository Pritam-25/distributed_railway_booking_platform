{
  "name": "distributed_railway_booking_platform",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "prepare": "husky",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "kafka:create-topics": "tsx scripts/create-kafka-topics.mts",
    "docker:build:user": "pnpm --filter user-service docker:build",
    "docker:run:user": "pnpm --filter user-service docker:run",
    "docker:build:notification": "pnpm --filter notification-service docker:build",
    "docker:run:notification": "pnpm --filter notification-service docker:run",
    "docker:build:gateway": "pnpm --filter api-gateway docker:build",
    "docker:run:gateway": "pnpm --filter api-gateway docker:run",
    "docker:build:admin": "pnpm --filter admin-service docker:build",
    "docker:run:admin": "pnpm --filter admin-service docker:run",
    "docker:run:dev": "docker compose --profile dev up -d",
    "docker:down:dev": "docker compose --profile dev down"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@irctc/contracts": "workspace:*",
    "@irctc/kafka": "workspace:*",
    "@irctc/logger": "workspace:*",
    "@types/node": "^22.19.21",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "turbo": "2.9.18",
    "typescript": "7.0.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
